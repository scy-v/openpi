    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": ["--config-name", "pi05_finetune_ur5e"],
            "env":{
                "OBS_INDICES": "28,29,30,31,32,33,7",
                "ACTION_INDICES": "1,2,3,4,5,6,7",
                "CUDA_VISIBLE_DEVICES": "4,5,6,7",
                "ACTION_SLICE": "6, -1",
                "URDF_PATH": "urdf/ur5e/ur5e.urdf"
            }
        }
    ]
}